generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  EMPLOYEE
  INTERN
  MANAGER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  password         String
  role             UserRole         @default(EMPLOYEE)
  designation      String?
  departmentId     String?
  managerId        String?
  createdById      String?
  department       Department?      @relation("DepartmentMembers", fields: [departmentId], references: [id])
  manager          User?            @relation("ManagerReports", fields: [managerId], references: [id])
  directReports    User[]           @relation("ManagerReports")
  createdBy        User?            @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers     User[]           @relation("UserCreator")
  headedDepartment Department?      @relation("DepartmentHead")
  ownedProjects    Project[]
  assignments      TaskAssignment[]
  reportedIssues   TaskIssue[]        @relation("ReportedIssues")
  resolvedIssues   TaskIssue[]        @relation("ResolvedIssues")
  attendances      Attendance[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Department {
  id          String @id @default(cuid())
  name        String @unique
  code        String @unique
  description String?
  headId      String? @unique
  head        User?   @relation("DepartmentHead", fields: [headId], references: [id])
  users       User[]  @relation("DepartmentMembers")
  projects    Project[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  departmentId String
  ownerId      String?
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  owner        User?      @relation(fields: [ownerId], references: [id])
  tasks        Task[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Task {
  id          String           @id @default(cuid())
  title       String
  description String?
  projectId   String?
  status      TaskStatus       @default(TODO)
  progress    Int              @default(0)
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignments TaskAssignment[]
  checklistItems TaskChecklistItem[]
  issues      TaskIssue[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TaskChecklistItem {
  id          String   @id @default(cuid())
  taskId       String
  title        String
  completed    Boolean  @default(false)
  completedAt  DateTime?
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TaskIssue {
  id              String   @id @default(cuid())
  taskId           String
  reporterId       String
  resolvedById     String?
  title            String
  description      String
  status           String   @default("OPEN")
  managerResponse  String?
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reporter         User     @relation("ReportedIssues", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy       User?    @relation("ResolvedIssues", fields: [resolvedById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
}

model Attendance {
  id        String    @id @default(cuid())
  userId    String
  date      DateTime
  checkIn   DateTime
  checkOut  DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
